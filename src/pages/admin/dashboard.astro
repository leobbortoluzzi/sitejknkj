---
import { env } from 'cloudflare:workers';

if (!env || !env.kv) {
    throw new Error("KV Namespace não encontrado no Cloudflare.");
}

const DEFAULT_DATA = {
  settings: {
    siteTitle: "Aura Clinic - Estética Avançada",
    metaDescription: "Especialista em tratamentos com resultados naturais.",
    primaryColor: "#d4af37",
    whatsappNumber: "5511999999999"
  },
  hero: {
    headline: "Realce sua beleza com naturalidade.",
    subheadline: "Estética de Alta Performance",
    backgroundImageUrl: "https://lh3.googleusercontent.com/aida-public/AB6AXuBJjNCfrgf3SCPPIgzpknodtCtjii-m0Btf4_FtA8nkGSWd4Y_Eua_8At0Og8XCgPwTV_zcs2Ylr2JXnLTAVWjtS2UefMACpIov153gmxxWmboNha-6rdepmKo2vh-dvtHqFDoBYqHTuVe7b5aPi_UVewMKazqEZvwGtuZWaV4RSJn5MNb8D-U0Z0FbtqozWQu2ils_1Aa1s9CzUfNmtigxiWrjMAlgRjsrhI3Y_GGvRyD7SgIZNHLEwVX5PG7FahxncSzgPLbsNtI3"
  },
  about: {},
  services: [],
  beforeAfter: [],
  testimonials: [],
  faq: [],
  contact: {}
};

const savedData = await env.kv.get("landing_page_data_v1", "json");
const data = savedData || DEFAULT_DATA;

const logs = await env.kv.get("site_logs", "json") || [];

const totalAccesses = logs.length;
const countries = {};
const cities = {};
const uas = {};

logs.forEach(l => {
    const c = l.country || 'Desconhecido';
    const city = l.city || 'Desconhecido';
    const ua = l.ua || 'Desconhecido';
    countries[c] = (countries[c] || 0) + 1;
    cities[city] = (cities[city] || 0) + 1;
    
    let device = "Desktop";
    if(ua.includes("Mobile") || ua.includes("Android") || ua.includes("iPhone")) device = "Mobile";
    uas[device] = (uas[device] || 0) + 1;
});

const topCountryArr = Object.entries(countries).sort((a,b)=>b[1]-a[1])[0] || ['N/A', 0];
const topCityArr = Object.entries(cities).sort((a,b)=>b[1]-a[1])[0] || ['N/A', 0];

const topCountry = { name: topCountryArr[0], count: topCountryArr[1] };
const topCity = { name: topCityArr[0], count: topCityArr[1] };
const mobileAccesses = uas['Mobile'] || 0;

const iconOptions = ['sparkles', 'check-circle', 'heart', 'star', 'shield', 'crown', 'sun', 'moon', 'flower', 'droplet', 'smile', 'activity', 'camera', 'scissors', 'syringe', 'wind'];
---
<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - LP Estética</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root[data-theme="dark"] {
            --bg: #0a0a0a;
            --sidebar: #050505;
            --card: #111111;
            --card-hover: #1a1a1a;
            --primary: #d4af37;
            --text: #ffffff;
            --text-muted: #a1a1aa;
            --border: rgba(255, 255, 255, 0.05);
            --input-bg: #080808;
            --danger: #ff4444;
            --success: #34d399;
        }

        :root[data-theme="light"] {
            --bg: #f8f9fa;
            --sidebar: #ffffff;
            --card: #ffffff;
            --card-hover: #f1f5f9;
            --primary: #d4af37;
            --text: #1a1a1a;
            --text-muted: #64748b;
            --border: rgba(0, 0, 0, 0.1);
            --input-bg: #ffffff;
            --danger: #ef4444;
            --success: #10b981;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; transition: background-color 0.3s, border-color 0.3s; }
        body { background: var(--bg); color: var(--text); display: flex; min-height: 100vh; overflow-x: hidden; }

        /* Sidebar */
        aside {
            width: 280px;
            background: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 40px 20px;
            position: fixed;
            height: 100vh;
            z-index: 50;
        }

        .logo { font-size: 1.2rem; font-weight: 600; color: var(--primary); margin-bottom: 60px; display: flex; align-items: center; gap: 10px; padding: 0 10px; }

        .nav-menu { list-style: none; flex: 1; display: flex; flex-direction: column; gap: 8px; }
        .nav-item { margin: 0; }
        .nav-link { 
            display: flex; 
            align-items: center; 
            gap: 14px; 
            padding: 14px 20px; 
            color: var(--text-muted); 
            text-decoration: none; 
            border-radius: 8px; 
            transition: all 0.2s;
            font-size: 0.95rem;
            cursor: pointer;
            font-weight: 500;
        }
        .nav-link:hover, .nav-link.active { background: var(--border); color: var(--text); }
        .nav-link i { width: 20px; }

        /* Theme Toggle */
        .theme-toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 20px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 8px;
            margin-bottom: 30px;
            cursor: pointer;
        }
        .theme-toggle span { font-size: 0.9rem; font-weight: 500; }

        /* Main Content */
        main { flex: 1; margin-left: 280px; padding: 40px 60px; }

        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        h1 { font-size: 1.5rem; font-weight: 500; }

        /* Tabs Logic */
        .tab-content { display: none; animation: fadeIn 0.3s ease-in-out; }
        .tab-content.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Dashboard Stats */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-bottom: 40px; }
        .stat-card { background: var(--card); padding: 30px; border-radius: 12px; border: 1px solid var(--border); }
        .stat-card label { color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 12px; font-weight: 600; }
        .stat-card span { font-size: 2rem; font-weight: 600; display: block; }
        .stat-card .sub-text { font-size: 0.85rem; color: var(--text-muted); margin-top: 8px; }

        /* Form / Sections */
        .card { background: var(--card); border-radius: 12px; border: 1px solid var(--border); padding: 40px; margin-bottom: 40px; }
        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px; }
        .card-title { font-size: 1.2rem; font-weight: 600; color: var(--primary); }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
        .form-group { margin-bottom: 0; }
        .form-group.full { grid-column: 1 / -1; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 500; color: var(--text-muted); margin-bottom: 10px; }
        .form-control { width: 100%; background: var(--input-bg); border: 1px solid var(--border); padding: 14px 16px; border-radius: 8px; color: var(--text); font-size: 0.95rem; }
        .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 1px var(--primary); }
        textarea.form-control { resize: vertical; min-height: 100px; }
        select.form-control { appearance: none; background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="%23d4af37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>'); background-repeat: no-repeat; background-position: right 16px center; padding-right: 40px; }

        .btn-save { background: var(--primary); color: #000; border: none; padding: 14px 28px; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 0.95rem; position: sticky; top: 20px; z-index: 100; box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3); transition: all 0.2s; }
        .btn-save:hover { filter: brightness(1.1); transform: translateY(-2px); }
        
        .array-item { background: var(--card-hover); border: 1px solid var(--border); padding: 30px; border-radius: 8px; margin-bottom: 24px; position: relative; }
        .remove-btn { position: absolute; top: 20px; right: 20px; background: rgba(239, 68, 68, 0.1); color: var(--danger); border: none; padding: 8px 14px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; font-weight: 600; transition: background 0.2s; }
        .remove-btn:hover { background: rgba(239, 68, 68, 0.2); }
        .add-btn { background: transparent; border: 1px dashed var(--primary); color: var(--primary); padding: 16px; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 500; width: 100%; transition: background 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .add-btn:hover { background: rgba(212, 175, 55, 0.05); }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { text-align: left; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; color: var(--text-muted); padding: 16px; border-bottom: 1px solid var(--border); white-space: nowrap; }
        td { padding: 16px; font-size: 0.9rem; border-bottom: 1px solid var(--border); color: var(--text); }
        .badge { padding: 6px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
        .badge-get { background: rgba(52, 211, 153, 0.1); color: var(--success); }
        .badge-post { background: rgba(96, 165, 250, 0.1); color: #60a5fa; }

        @media (max-width: 1024px) {
            aside { width: 80px; padding: 20px 10px; }
            .logo span, .nav-link span, .theme-toggle span { display: none; }
            .theme-toggle { justify-content: center; }
            main { margin-left: 80px; padding: 30px; }
            .form-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <aside>
        <div class="logo">
            <i data-lucide="sparkles"></i>
            <span>Painel Estética</span>
        </div>
        
        <div class="theme-toggle" onclick="toggleTheme()" title="Alternar Tema">
            <span>Tema Escuro</span>
            <i data-lucide="moon" id="themeIcon"></i>
        </div>

        <nav class="nav-menu">
            <div class="nav-item">
                <a class="nav-link active" onclick="switchTab('dashboard', this)">
                    <i data-lucide="layout-dashboard"></i>
                    <span>Dashboard</span>
                </a>
            </div>
            <div class="nav-item">
                <a class="nav-link" onclick="switchTab('content', this)">
                    <i data-lucide="file-text"></i>
                    <span>Conteúdo LP</span>
                </a>
            </div>
            <div class="nav-item">
                <a class="nav-link" onclick="switchTab('accesses', this)">
                    <i data-lucide="activity"></i>
                    <span>Acessos</span>
                </a>
            </div>
        </nav>
        <div class="nav-item" style="margin-top: auto;">
            <a href="/api/admin/logout" class="nav-link">
                <i data-lucide="log-out"></i>
                <span>Sair</span>
            </a>
        </div>
    </aside>

    <main>
        <!-- TAB: DASHBOARD -->
        <div id="dashboard" class="tab-content active">
            <header>
                <h1>Visão Geral</h1>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <label>Total de Acessos (KV)</label>
                    <span>{totalAccesses}</span>
                    <div class="sub-text">Últimos 50 mantidos</div>
                </div>
                <div class="stat-card">
                    <label>Dispositivos</label>
                    <span>{mobileAccesses}</span>
                    <div class="sub-text">Acessos via Mobile</div>
                </div>
                <div class="stat-card">
                    <label>País Destaque</label>
                    <span>{topCountry.name}</span>
                    <div class="sub-text">{topCountry.count} visitas</div>
                </div>
                <div class="stat-card">
                    <label>Cidade Destaque</label>
                    <span>{topCity.name}</span>
                    <div class="sub-text">{topCity.count} visitas</div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Acessos Recentes (Top 5)</h3>
                    <a href="#" style="color: var(--primary); font-size: 0.9rem; font-weight: 500; text-decoration: none;" onclick="switchTab('accesses', document.querySelectorAll('.nav-link')[2])">Ver todos &rarr;</a>
                </div>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Origem</th>
                                <th>Dispositivo</th>
                                <th>Provedor (ASN)</th>
                            </tr>
                        </thead>
                        <tbody>
                            {logs.length > 0 ? logs.slice(0, 5).map(log => {
                                let dev = "Desktop";
                                if(log.ua?.includes("Mobile") || log.ua?.includes("Android") || log.ua?.includes("iPhone")) dev = "Mobile";
                                return (
                                <tr>
                                    <td>{new Date(log.timestamp).toLocaleString('pt-BR')}</td>
                                    <td>{log.city || '-'}, {log.country || '-'}</td>
                                    <td>{dev}</td>
                                    <td style="font-size: 0.75rem; color: var(--text-muted);">{log.asn || '-'}</td>
                                </tr>
                                )
                            }) : <tr><td colspan="4">Nenhum dado recente.</td></tr>}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB: CONTENT -->
        <div id="content" class="tab-content">
            <header>
                <h1>Conteúdo da Landing Page</h1>
                <button class="btn-save" onclick="saveAll()">Salvar Alterações</button>
            </header>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">1. Configurações Gerais</h3>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Título do Site (Aba do Navegador)</label>
                        <input type="text" class="form-control" id="siteTitle" value={data.settings?.siteTitle || ''} placeholder="Ex: Aura Clinic - Estética Avançada">
                    </div>
                    <div class="form-group">
                        <label>Descrição do Site (SEO)</label>
                        <input type="text" class="form-control" id="metaDescription" value={data.settings?.metaDescription || ''} placeholder="Sua clínica especializada em...">
                    </div>
                    <div class="form-group">
                        <label>WhatsApp (Somente números com DDD)</label>
                        <input type="text" class="form-control" id="whatsappNumber" value={data.settings?.whatsappNumber || ''} placeholder="Ex: 5511999999999">
                    </div>
                    <div class="form-group">
                        <label>Cor Principal (Hexadecimal)</label>
                        <input type="color" class="form-control" style="height: 52px; padding: 5px;" id="primaryColor" value={data.settings?.primaryColor || '#cf1763'}>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">2. Hero Section (Topo)</h3>
                </div>
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Imagem de Fundo (URL)</label>
                        <input type="text" class="form-control" id="heroBg" value={data.hero?.backgroundImageUrl || ''} placeholder="https://exemplo.com/imagem.jpg">
                    </div>
                    <div class="form-group full">
                        <label>Título Principal (Headline)</label>
                        <input type="text" class="form-control" id="heroHeadline" value={data.hero?.headline || ''} placeholder="Realce sua beleza com naturalidade.">
                    </div>
                    <div class="form-group full">
                        <label>Texto de Apoio (Subheadline)</label>
                        <textarea class="form-control" id="heroSubheadline" rows="2" placeholder="Estética de Alta Performance">{data.hero?.subheadline || ''}</textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">3. Sobre a Clínica / Profissional</h3>
                </div>
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Imagem (URL)</label>
                        <input type="text" class="form-control" id="aboutImage" value={data.about?.imageUrl || ''} placeholder="https://exemplo.com/foto-clinica.jpg">
                    </div>
                    <div class="form-group">
                        <label>Título / Nome</label>
                        <input type="text" class="form-control" id="aboutName" value={data.about?.name || ''} placeholder="Ex: Excelência em cada detalhe">
                    </div>
                    <div class="form-group">
                        <label>Subtítulo / Missão</label>
                        <input type="text" class="form-control" id="aboutRole" value={data.about?.role || ''} placeholder="Ex: Nossa Missão">
                    </div>
                    <div class="form-group full">
                        <label>Texto de Descrição (Bio)</label>
                        <textarea class="form-control" id="aboutBio" rows="4" placeholder="Conte a história da sua clínica ou profissional...">{data.about?.bio || ''}</textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">4. Tratamentos / Serviços</h3>
                </div>
                <div id="servicesContainer">
                    <!-- Javascript will inject items here -->
                </div>
                <button class="add-btn" onclick="addService()">
                    <i data-lucide="plus"></i> Adicionar Tratamento
                </button>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">5. Resultados (Antes e Depois)</h3>
                </div>
                <div id="baContainer">
                    <!-- Javascript will inject items here -->
                </div>
                <button class="add-btn" onclick="addBA()">
                    <i data-lucide="plus"></i> Adicionar Resultado
                </button>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">6. Depoimentos</h3>
                </div>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 15px;">Adicione avaliações de clientes.</p>
                <div id="testContainer">
                    <!-- Javascript will inject items here -->
                </div>
                <button class="add-btn" onclick="addTest()">
                    <i data-lucide="plus"></i> Adicionar Depoimento
                </button>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">7. FAQ & Contato</h3>
                </div>
                <div class="form-group full" style="margin-bottom: 40px;">
                    <label style="color: var(--primary); font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 24px;">Dúvidas Frequentes</label>
                    <div id="faqContainer">
                        <!-- Javascript will inject items here -->
                    </div>
                    <button class="add-btn" onclick="addFAQ()">
                        <i data-lucide="plus"></i> Adicionar Pergunta
                    </button>
                </div>
                
                <div class="form-grid pt-4" style="border-top: 1px solid var(--border); padding-top: 30px;">
                    <div class="form-group full">
                        <label style="color: var(--primary); font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 24px;">Localização e Atendimento</label>
                    </div>
                    <div class="form-group full">
                        <label>Endereço Físico (Opcional)</label>
                        <input type="text" class="form-control" id="contactAddress" value={data.contact?.address || ''} placeholder="Ex: Av. Paulista, 1000 - Bela Vista, São Paulo - SP">
                    </div>
                    <div class="form-group full">
                        <label>Google Maps Embed (src URL)</label>
                        <input type="text" class="form-control" id="contactMap" value={data.contact?.mapEmbedUrl || ''} placeholder="https://www.google.com/maps/embed?pb=...">
                        <small style="color: var(--text-muted); font-size: 0.75rem; margin-top: 5px; display: block;">No Google Maps, clique em Compartilhar > Incorporar um mapa > Copie apenas o link dentro do src="".</small>
                    </div>
                    <div class="form-group full">
                        <label>Horário de Atendimento</label>
                        <input type="text" class="form-control" id="contactHours" value={data.contact?.openingHours || ''} placeholder="Segunda a Sexta: 09h às 19h">
                    </div>

                    <div class="form-group full" style="margin-top: 20px;">
                        <label style="color: var(--primary); font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 24px;">Redes Sociais</label>
                    </div>
                    <div class="form-group">
                        <label>Link do Instagram</label>
                        <input type="text" class="form-control" id="contactInsta" value={data.contact?.instagram || ''} placeholder="https://instagram.com/suaclinica">
                    </div>
                    <div class="form-group">
                        <label>Widget do Feed Instagram (Código Elfsight/Embed)</label>
                        <textarea class="form-control" id="contactInstaFeed" rows="2" placeholder="Cole aqui a div do widget (Opcional)">{data.contact?.instagramFeed || ''}</textarea>
                    </div>
                    <div class="form-group">
                        <label>Link do Facebook</label>
                        <input type="text" class="form-control" id="contactFb" value={data.contact?.facebook || ''} placeholder="https://facebook.com/suaclinica">
                    </div>
                    <div class="form-group">
                        <label>Link do TikTok</label>
                        <input type="text" class="form-control" id="contactTiktok" value={data.contact?.tiktok || ''} placeholder="https://tiktok.com/@suaclinica">
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: ACCESSES -->
        <div id="accesses" class="tab-content">
            <header>
                <h1>Histórico de Acessos</h1>
            </header>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Todos os Logs (Até 50)</h3>
                </div>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Método / HTTP</th>
                                <th>IP</th>
                                <th>Localização / Fuso</th>
                                <th>Provedor</th>
                                <th>DC (Colo)</th>
                                <th>User Agent</th>
                            </tr>
                        </thead>
                        <tbody>
                            {logs.length > 0 ? logs.map(log => (
                                <tr>
                                    <td style="white-space: nowrap;">{new Date(log.timestamp).toLocaleString('pt-BR')}</td>
                                    <td><span class={`badge badge-${log.method ? log.method.toLowerCase() : 'get'}`}>{log.method || 'GET'}</span> <span style="font-size:0.7rem; color:var(--text-muted);">{log.protocol || ''}</span></td>
                                    <td>{log.ip || '-'}</td>
                                    <td>{log.city || '-'}, {log.country || '-'} <br/><small style="color:var(--primary);">{log.timezone || ''}</small></td>
                                    <td style="font-size: 0.8rem;">{log.asn || '-'}</td>
                                    <td style="font-size: 0.8rem;">{log.colo || '-'}</td>
                                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title={log.ua || ''}>{log.ua || '-'}</td>
                                </tr>
                            )) : <tr><td colspan="7">Nenhum log encontrado.</td></tr>}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script id="admin-data-json" type="application/json" set:html={JSON.stringify(data).replace(/</g, '\\u003c')}></script>
    <script id="admin-icons-json" type="application/json" set:html={JSON.stringify(iconOptions)}></script>

    <script>
        // Init Icons
        lucide.createIcons();

        // Theme Toggle Logic
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            
            const themeText = document.querySelector('.theme-toggle span');
            themeText.textContent = newTheme === 'dark' ? 'Tema Escuro' : 'Tema Claro';
            
            const icon = document.getElementById('themeIcon');
            icon.setAttribute('data-lucide', newTheme === 'dark' ? 'moon' : 'sun');
            lucide.createIcons();
            
            localStorage.setItem('admin_theme', newTheme);
        }

        // Restore Theme
        const savedTheme = localStorage.getItem('admin_theme') || 'dark';
        if(savedTheme !== 'dark') {
            document.documentElement.setAttribute('data-theme', savedTheme);
            document.querySelector('.theme-toggle span').textContent = 'Tema Claro';
            document.getElementById('themeIcon').setAttribute('data-lucide', 'sun');
            lucide.createIcons();
        }

        // Tab Switch Logic
        function switchTab(tabId, el) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            
            document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
            el.classList.add('active');
            window.scrollTo(0,0);
        }

        // Make switchTab available globally
        window.switchTab = switchTab;
        window.toggleTheme = toggleTheme;

        // --- Dynamic Arrays Logic ---
        
        const initialData = JSON.parse(document.getElementById('admin-data-json').textContent);
        const iconOptions = JSON.parse(document.getElementById('admin-icons-json').textContent);

        // SERVICES
        const servicesContainer = document.getElementById('servicesContainer');
        function renderService(service = {title:'', icon:'sparkles', description:''}) {
            const div = document.createElement('div');
            div.className = 'array-item service-item';
            
            const selectOptions = iconOptions.map(opt => 
                `<option value="${opt}" ${service.icon === opt ? 'selected' : ''}>${opt}</option>`
            ).join('');

            div.innerHTML = `
                <button class="remove-btn" onclick="this.parentElement.remove()" title="Remover"><i data-lucide="trash-2" style="width:16px; height:16px;"></i></button>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Título do Serviço</label>
                        <input type="text" class="form-control s-title" value="${service.title}" placeholder="Ex: Harmonização Facial">
                    </div>
                    <div class="form-group">
                        <label>Ícone (Lucide)</label>
                        <select class="form-control s-icon">
                            ${selectOptions}
                        </select>
                    </div>
                    <div class="form-group full">
                        <label>Descrição</label>
                        <textarea class="form-control s-desc" rows="2" placeholder="Breve descrição do tratamento...">${service.description}</textarea>
                    </div>
                </div>
            `;
            servicesContainer.appendChild(div);
            lucide.createIcons();
        }
        window.addService = () => renderService();
        (initialData.services || []).forEach(s => renderService(s));
        if(!initialData.services || initialData.services.length === 0) renderService();

        // BEFORE / AFTER
        const baContainer = document.getElementById('baContainer');
        function renderBA(ba = {beforeUrl:'', afterUrl:'', label:''}) {
            const div = document.createElement('div');
            div.className = 'array-item ba-item';
            div.innerHTML = `
                <button class="remove-btn" onclick="this.parentElement.remove()" title="Remover"><i data-lucide="trash-2" style="width:16px; height:16px;"></i></button>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Imagem Antes (URL)</label>
                        <input type="text" class="form-control ba-before" value="${ba.beforeUrl}" placeholder="https://exemplo.com/antes.jpg">
                    </div>
                    <div class="form-group">
                        <label>Imagem Depois (URL)</label>
                        <input type="text" class="form-control ba-after" value="${ba.afterUrl}" placeholder="https://exemplo.com/depois.jpg">
                    </div>
                    <div class="form-group full">
                        <label>Nome do Procedimento</label>
                        <input type="text" class="form-control ba-label" value="${ba.label}" placeholder="Ex: Protocolo Rejuvenescimento">
                    </div>
                </div>
            `;
            baContainer.appendChild(div);
            lucide.createIcons();
        }
        window.addBA = () => renderBA();
        (initialData.beforeAfter || []).forEach(b => renderBA(b));
        if(!initialData.beforeAfter || initialData.beforeAfter.length === 0) renderBA();

        // TESTIMONIALS
        const testContainer = document.getElementById('testContainer');
        function renderTest(test = {name:'', content:'', rating:5}) {
            const div = document.createElement('div');
            div.className = 'array-item test-item';
            div.innerHTML = `
                <button class="remove-btn" onclick="this.parentElement.remove()" title="Remover"><i data-lucide="trash-2" style="width:16px; height:16px;"></i></button>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Nome do Cliente</label>
                        <input type="text" class="form-control t-name" value="${test.name}" placeholder="Ex: Maria Silva">
                    </div>
                    <div class="form-group">
                        <label>Avaliação (1 a 5)</label>
                        <input type="number" class="form-control t-rating" min="1" max="5" value="${test.rating}" placeholder="5">
                    </div>
                    <div class="form-group full">
                        <label>Depoimento</label>
                        <textarea class="form-control t-content" rows="2" placeholder="O que o cliente disse...">${test.content}</textarea>
                    </div>
                </div>
            `;
            testContainer.appendChild(div);
            lucide.createIcons();
        }
        window.addTest = () => renderTest();
        (initialData.testimonials || []).forEach(t => renderTest(t));
        if(!initialData.testimonials || initialData.testimonials.length === 0) renderTest();

        // FAQ
        const faqContainer = document.getElementById('faqContainer');
        function renderFAQ(faqItem = {question:'', answer:''}) {
            const div = document.createElement('div');
            div.className = 'array-item faq-item';
            div.innerHTML = `
                <button class="remove-btn" onclick="this.parentElement.remove()" title="Remover"><i data-lucide="trash-2" style="width:16px; height:16px;"></i></button>
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Pergunta</label>
                        <input type="text" class="form-control faq-q" value="${faqItem.question}" placeholder="Ex: Os procedimentos doem?">
                    </div>
                    <div class="form-group full">
                        <label>Resposta</label>
                        <textarea class="form-control faq-a" rows="3" placeholder="Sua resposta...">${faqItem.answer}</textarea>
                    </div>
                </div>
            `;
            faqContainer.appendChild(div);
            lucide.createIcons();
        }
        window.addFAQ = () => renderFAQ();
        (initialData.faq || []).forEach(f => renderFAQ(f));
        if(!initialData.faq || initialData.faq.length === 0) renderFAQ();

        // SAVE LOGIC
        window.saveAll = async () => {
            const btn = document.querySelector('.btn-save');
            const originalText = btn.textContent;
            btn.textContent = 'Salvando...';
            btn.disabled = true;

            // Collect Services
            const services = [];
            document.querySelectorAll('.service-item').forEach(item => {
                const title = item.querySelector('.s-title').value.trim();
                if(title) {
                    services.push({
                        title: title,
                        icon: item.querySelector('.s-icon').value.trim() || 'sparkles',
                        description: item.querySelector('.s-desc').value.trim()
                    });
                }
            });

            // Collect BA
            const beforeAfter = [];
            document.querySelectorAll('.ba-item').forEach(item => {
                const bUrl = item.querySelector('.ba-before').value.trim();
                if(bUrl) {
                    beforeAfter.push({
                        beforeUrl: bUrl,
                        afterUrl: item.querySelector('.ba-after').value.trim(),
                        label: item.querySelector('.ba-label').value.trim()
                    });
                }
            });

            // Collect Testimonials
            const testimonials = [];
            document.querySelectorAll('.test-item').forEach(item => {
                const name = item.querySelector('.t-name').value.trim();
                if(name) {
                    testimonials.push({
                        name: name,
                        rating: parseInt(item.querySelector('.t-rating').value) || 5,
                        content: item.querySelector('.t-content').value.trim()
                    });
                }
            });

            // Collect FAQ
            const faq = [];
            document.querySelectorAll('.faq-item').forEach(item => {
                const q = item.querySelector('.faq-q').value.trim();
                if(q) {
                    faq.push({
                        question: q,
                        answer: item.querySelector('.faq-a').value.trim()
                    });
                }
            });

            const newData = {
                settings: {
                    siteTitle: document.getElementById('siteTitle').value.trim(),
                    metaDescription: document.getElementById('metaDescription').value.trim(),
                    primaryColor: document.getElementById('primaryColor').value,
                    whatsappNumber: document.getElementById('whatsappNumber').value.trim(),
                    logoUrl: ""
                },
                hero: {
                    headline: document.getElementById('heroHeadline').value.trim(),
                    subheadline: document.getElementById('heroSubheadline').value.trim(),
                    backgroundImageUrl: document.getElementById('heroBg').value.trim()
                },
                about: {
                    imageUrl: document.getElementById('aboutImage').value.trim(),
                    name: document.getElementById('aboutName').value.trim(),
                    role: document.getElementById('aboutRole').value.trim(),
                    bio: document.getElementById('aboutBio').value.trim()
                },
                services: services,
                beforeAfter: beforeAfter,
                testimonials: testimonials,
                faq: faq,
                contact: {
                    address: document.getElementById('contactAddress').value.trim(),
                    mapEmbedUrl: document.getElementById('contactMap').value.trim(),
                    instagram: document.getElementById('contactInsta').value.trim(),
                    instagramFeed: document.getElementById('contactInstaFeed').value.trim(),
                    facebook: document.getElementById('contactFb').value.trim(),
                    tiktok: document.getElementById('contactTiktok').value.trim(),
                    openingHours: document.getElementById('contactHours').value.trim()
                }
            };

            try {
                const res = await fetch('/api/admin/update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(newData)
                });

                if (res.ok) {
                    btn.textContent = 'Salvo com sucesso!';
                    btn.style.background = 'var(--success)';
                    btn.style.color = '#fff';
                    setTimeout(() => {
                        btn.style.background = '';
                        btn.style.color = '';
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }, 2000);
                } else {
                    alert('Erro ao salvar. Verifique sua conexão.');
                    btn.textContent = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Erro de conexão.');
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
